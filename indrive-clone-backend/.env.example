# docker-compose secrets — copy to `.env` (gitignored) and fill with real values.
#   cp .env.example .env
# Generate a strong JWT secret with:  openssl rand -base64 48

# Shared HMAC secret for JWTs. MUST be >= 32 chars and identical for the
# gateway and the realtime service (which verifies WS tokens with it).
JWT_SECRET=

# Postgres
POSTGRES_USER=indrive
POSTGRES_PASSWORD=
POSTGRES_DB=indrive

# MongoDB (ride event logs)
MONGO_USER=indrive
MONGO_PASSWORD=

# Comma-separated WebSocket origin allowlist (host[:port]); no scheme.
ALLOWED_ORIGINS=localhost:5173,localhost:3000
