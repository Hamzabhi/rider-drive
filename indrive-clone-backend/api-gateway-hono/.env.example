# API Gateway (Hono.js / Bun)
PORT=8080
JWT_SECRET=replace-me-with-a-64-char-secret
JWT_EXPIRES_IN=7d

# Postgres (persistent users/rides)
DATABASE_URL=postgresql://indrive:indrive@localhost:5432/indrive

# Redis (shared with realtime-go)
REDIS_URL=redis://localhost:6379

# gRPC targets
PRICING_GRPC_ADDR=localhost:50051   # computation-rust
MATCHING_GRPC_ADDR=localhost:50052  # realtime-go
